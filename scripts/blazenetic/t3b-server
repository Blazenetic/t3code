#!/usr/bin/env bash
# t3b-server — launch only the T3 Code server from the live source tree.
set -Eeuo pipefail

_self="$(readlink -f "${BASH_SOURCE[0]}")"
# shellcheck source=lib/common.sh
source "$(dirname "$_self")/lib/common.sh"

usage() {
  cat >&2 <<'EOF'
Usage: t3b-server [-- <server args>]
  Launch only the backend (`vp run dev:server`) from the live working tree.
  Arguments such as --host and --no-browser are passed through unchanged.
EOF
}

case "${1:-}" in -h|--help) usage; exit 0 ;; esac

t3b::load_env
repo="$(t3b::repo)"
t3b::ensure_vp
t3b::require_deps "$repo" || t3b::die "Install dependencies before running dev."
t3b::apply_otlp_env

t3b::info "Repo:   $repo"
t3b::info "Branch: $(t3b::branch "$repo")"
t3b::info "Running: vp run dev:server"
cd "$repo"
exec vp run dev:server "$@"

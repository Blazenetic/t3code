# .env.blazenetic.example — configuration for the t3b* wrapper scripts ONLY.
#
# These variables configure the downstream development wrappers, NOT the T3 Code
# application itself. Copy this file to either:
#   ~/.config/t3code-blazenetic/env      (user-global), or
#   <repo>/.env.blazenetic               (per-clone)
# and edit as needed. Both locations are auto-loaded by the wrappers if present.
#
# Never commit secrets. This file intentionally contains no credentials.

# Path to the live T3 Code working tree.
T3B_REPO="$HOME/Code/t3code"

# Long-lived downstream branch the wrappers launch/check against.
T3B_BRANCH="blazenetic"

# Terminal emulator used by the KDE launcher (konsole or alacritty).
T3B_TERMINAL="konsole"

# Default dev mode hint (desktop|web|dev). Informational for your own tooling;
# `t3b` runs full dev, `t3b-web` runs web, `t3b-desktop` runs desktop.
T3B_DEV_MODE="desktop"

# Active long-lived feature. `t3b-feature use` normally manages this via a
# separate config file; uncomment to override it from the environment.
# T3B_FEATURE_BRANCH="feature/blazeprovements"

# Fetch-free status snapshots are available with `t3b-upstream --no-fetch`.
# Control how many unseen upstream commits are printed at call time with
# `t3b-upstream --log N` (there is no persistent setting required).

# Convenience switch for server-bearing launchers: t3b, t3b-server, and
# t3b-desktop. Conventional true/false values are accepted. Changing these
# values requires a full server restart.
T3B_OTLP=0

# Explicit application values take precedence over the local defaults injected
# when T3B_OTLP=1. Leave commented to use 127.0.0.1:4318 automatically.
# T3CODE_OTLP_TRACES_URL="http://127.0.0.1:4318/v1/traces"
# T3CODE_OTLP_METRICS_URL="http://127.0.0.1:4318/v1/metrics"
# T3CODE_OTLP_SERVICE_NAME="t3-blazenetic"

# Managed local Grafana LGTM container. Docker is preferred automatically;
# set T3B_OBS_ENGINE=podman (or another compatible executable) to override.
# T3B_OBS_ENGINE="docker"
T3B_OBS_IMAGE="grafana/otel-lgtm:latest"
T3B_OBS_CONTAINER="t3code-blazenetic-lgtm"
T3B_OBS_GRAFANA_URL="http://127.0.0.1:3000"

# Optional host-port overrides. Every mapping remains bound to 127.0.0.1.
# T3B_OBS_GRAFANA_PORT=3000
# T3B_OBS_OTLP_GRPC_PORT=4317
# T3B_OBS_OTLP_HTTP_PORT=4318
